# WPS Absence Manager Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3000
JWT_SECRET=change-this-to-a-random-string

# Twilio SMS (get these from https://console.twilio.com)
TWILIO_SID=your_twilio_account_sid
TWILIO_AUTH=your_twilio_auth_token
TWILIO_FROM=+61400000000

# SendGrid Email (get this from https://app.sendgrid.com)
SENDGRID_KEY=your_sendgrid_api_key
SENDGRID_FROM=absence@wps.edu.au

# Set to 'true' to enable real SMS/email (leave 'false' for testing)
NOTIFICATIONS_LIVE=false
